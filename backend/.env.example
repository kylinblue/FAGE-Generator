# FAGE Character Generator - Environment Configuration
# Copy this file to .env and customize as needed

# API Settings
API_TITLE=FAGE Character Generator API
API_VERSION=2.0.0
API_DESCRIPTION=REST API for Fantasy AGE character management

# CORS Settings
# Using default values from config.py (recommended for local development)
# To override, use JSON array format: CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Server Settings
HOST=0.0.0.0
PORT=8000
RELOAD=true

# Storage Settings
STORAGE_DIR=storage/characters

# Data Settings
CSV_DIR=data/csv
